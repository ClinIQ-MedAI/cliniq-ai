# ClinIQ async job-queue configuration.
# Copy to `.env` (gitignored) in each service dir, or export before launching.
# Leave QUEUE_BACKEND unset/none to keep services synchronous (HTTP-only).

# ----- broker selection -----------------------------------------------------
# redis | rabbitmq | none
QUEUE_BACKEND=redis

# ----- Redis (Upstash / ElastiCache / self-hosted) --------------------------
# Accepts the StackExchange.Redis / .NET style the backend already uses:
#   host:port,password=...,ssl=true
REDIS_CONNECTION=causal-leopard-72320.upstash.io:6379,password=YOUR_TOKEN_HERE,ssl=true
# ...or a standard URL instead (use rediss:// for TLS):
# REDIS_URL=rediss://default:YOUR_TOKEN@causal-leopard-72320.upstash.io:6379

# ----- RabbitMQ (only if QUEUE_BACKEND=rabbitmq) ----------------------------
# RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# ----- channel / behaviour tuning (optional; defaults shown) ----------------
# QUEUE_PREFIX=cliniq                  # jobs -> cliniq:jobs:<modality>, results -> cliniq:results
# QUEUE_GROUP=cliniq-workers           # Redis consumer group
# QUEUE_RESULT_CHANNEL=cliniq:results  # where workers publish ResultMessages
# QUEUE_BLOCK_MS=5000                  # broker blocking-read timeout
# QUEUE_MAXLEN=10000                   # approx Redis stream length cap
