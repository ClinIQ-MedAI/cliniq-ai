#!/bin/bash
# ClinIQ — ENTIRE stack on one shared GPU (SLURM batch job)
#
# Runs the whole ClinIQ platform INSIDE a single L40S allocation:
#   LLM (Ollama gpt-oss:20b on GPU) + LiteLLM proxy
#   bone-detect (:8001)  oral-xray (:8002)  chest-xray (:8003)  oral-classify (:8004)
#   chatbot (:5000)
#
# Everything runs on the SAME node and shares the SAME GPU, so every model sees
# torch.cuda.is_available() == True and the chatbot reaches each service over
# 127.0.0.1 (which is how chatbot-app/core/settings.py is wired).
#
# Submit:  sbatch slurm/cliniq_gpu_shared.sbatch
# Watch:   tail -f slurm/cliniq_gpu_shared-<jobid>.log
# Reach:   ssh -L 5000:<node>:5000 <login-node>   then open http://127.0.0.1:5000
# Stop:    scancel <jobid>
#
#SBATCH --job-name=cliniq-gpu-shared
#SBATCH --account=thetan-ai
#SBATCH --gres=gpu:L40S:1
#SBATCH --cpus-per-task=32
#SBATCH --mem=128G
#SBATCH --time=7-00:00:00
#SBATCH --output=slurm/cliniq_gpu_shared-%j.log

set -uo pipefail   # NOT -e: one flaky service must not tear down the whole stack

ROOT="/data/user/moabouag/far/cliniq"
LLM_MODEL="${CLINIQ_LLM_MODEL:-gpt-oss:20b}"

ENDPOINT_FILE="$ROOT/.local/cliniq_shared_gpu_endpoint.txt"
SUMMARY_FILE="$ROOT/.local/cliniq_shared_summary.txt"
READY_FILE="$ROOT/.local/cliniq_shared_ready"

# Clean stale markers from a previous run.
rm -f "$ENDPOINT_FILE" "$SUMMARY_FILE" "$READY_FILE"

NODE_HOST="$(hostname)"

echo "==================================================================="
echo "ClinIQ — FULL STACK on shared GPU"
echo "  node:  $NODE_HOST"
echo "  gpus:  ${CUDA_VISIBLE_DEVICES:-?}"
echo "  llm:   $LLM_MODEL"
echo "  time:  $(date)"
echo "==================================================================="

# --- environment ---------------------------------------------------------------
source /u/moabouag/miniforge3/etc/profile.d/conda.sh
conda activate r

cd "$ROOT"
echo "$NODE_HOST" > "$ENDPOINT_FILE"
echo "[shared] endpoint published: $NODE_HOST"

# Queue config (QUEUE_BACKEND / REDIS_CONNECTION / ...) comes from the repo-root
# .env, exactly like runs.sh does. Exported here so every service spawned below
# — the x-ray workers and triage — sees it. Unset => everything stays HTTP-only.
set -a
[ -f "$ROOT/.env" ] && source "$ROOT/.env"
set +a
QUEUE_MODE="${QUEUE_BACKEND:-none}"
echo "[shared] queue backend: $QUEUE_MODE"

# --- 1) LLM on GPU: Ollama + LiteLLM proxy ------------------------------------
OLLAMA_DIR="$ROOT/.local/ollama"
OLLAMA_BIN="$OLLAMA_DIR/bin/ollama"
export OLLAMA_MODELS="$OLLAMA_DIR/data"
export OLLAMA_HOST="127.0.0.1:11434"
export OLLAMA_KEEP_ALIVE="-1"                       # keep the model resident in VRAM
export LD_LIBRARY_PATH="$OLLAMA_DIR/lib/ollama:${LD_LIBRARY_PATH:-}"

if [ -x "$OLLAMA_BIN" ]; then
  echo "[shared] starting Ollama on GPU ..."
  "$OLLAMA_BIN" serve > /tmp/cliniq_shared_ollama.log 2>&1 &
  for _i in $(seq 1 30); do
    curl -s -o /dev/null "http://127.0.0.1:11434/api/version" && break
    sleep 1
  done

  if ! "$OLLAMA_BIN" list 2>/dev/null | grep -q "${LLM_MODEL%%:*}"; then
    echo "[shared] pulling $LLM_MODEL (first run only) ..."
    "$OLLAMA_BIN" pull "$LLM_MODEL"
  fi

  # Warm the model so it's resident in VRAM before the summary probes /api/ps.
  echo "[shared] warming $LLM_MODEL on GPU ..."
  curl -s "http://127.0.0.1:11434/api/chat" -d "{
    \"model\": \"$LLM_MODEL\",
    \"messages\": [{\"role\": \"user\", \"content\": \"ok\"}],
    \"stream\": false
  }" > /dev/null 2>&1 || true

  # Local LiteLLM config: primary = jetstream, fallback = this node's GPU Ollama.
  cat > "$ROOT/llm-gateway/config.shared.yaml" <<YAML
# AUTO-GENERATED by cliniq_gpu_shared.sbatch — fallback served from THIS GPU node.
model_list:
  - model_name: gpt-oss-120b
    litellm_params:
      model: openai/gpt-oss-120b
      api_base: https://llm.jetstream-cloud.org/api
      api_key: os.environ/JETSTREAM_API_KEY
      # A 10s cap cut long streamed reports mid-sentence: jetstream starts
      # streaming, the timeout fires, and LiteLLM cannot fall back once bytes are
      # already flowing, so the chatbot got a truncated report. A dead jetstream
      # still fails fast (connection refused is immediate), so 90s only helps a
      # slow-but-working stream finish.
      timeout: 90
  - model_name: local-fallback
    litellm_params:
      model: ollama/$LLM_MODEL
      api_base: http://127.0.0.1:11434
      timeout: 120
router_settings:
  fallbacks:
    - gpt-oss-120b: ["local-fallback"]
  num_retries: 0
  timeout: 120
  cooldown_time: 120
litellm_settings:
  drop_params: true
YAML

  # Upstream key for the primary (jetstream) model group.
  set -a
  [ -f "$ROOT/chatbot-app/.env" ] && source "$ROOT/chatbot-app/.env"
  set +a
  export JETSTREAM_API_KEY="${API_KEY:-}"

  echo "[shared] starting LiteLLM proxy (:4000) ..."
  litellm --config "$ROOT/llm-gateway/config.shared.yaml" --port 4000 \
    > /tmp/cliniq_shared_litellm.log 2>&1 &
  for _i in $(seq 1 40); do
    curl -s -o /dev/null "http://127.0.0.1:4000/health/liveliness" && break
    sleep 1
  done

  # A dead proxy is silent: the chatbot boots fine and just answers "I'm unable
  # to access the LLM service". Fail loudly instead of letting that slip through.
  if ! curl -s -o /dev/null --max-time 3 "http://127.0.0.1:4000/health/liveliness"; then
    echo "[shared] ✗✗ LiteLLM proxy FAILED to start — the chatbot will have NO LLM."
    echo "[shared]    last lines of /tmp/cliniq_shared_litellm.log:"
    tail -n 6 /tmp/cliniq_shared_litellm.log 2>/dev/null | sed 's/^/[shared]    | /'
  else
    echo "[shared] ✓ LiteLLM proxy up on :4000"
  fi
else
  echo "[shared] ! Ollama binary not found at $OLLAMA_BIN — LLM will use remote only"
fi

# Route the chatbot through the local proxy (fallback = this GPU's Ollama).
export API_BASE_URL="http://127.0.0.1:4000/"
export API_KEY="local-fallback-gateway"
export MODEL="gpt-oss-120b"

# --- 2) X-ray models (all on this GPU) ----------------------------------------
wait_health() {  # port name
  for _i in $(seq 1 45); do
    curl -s -o /dev/null "http://127.0.0.1:$1/health" 2>/dev/null && {
      echo "[shared] ✓ $2 ready on :$1"; return 0; }
    sleep 2
  done
  echo "[shared] ✗ $2 timed out on :$1"; return 1
}

# Start a service and fan its output out two ways: the full copy into a
# node-local /tmp file, and a prefixed copy into THIS job's stdout (the SLURM
# log you tail). Each service's own middleware already tags request lines with
# [service]; the extra prefix keeps its startup/warning lines attributable too.
# PYTHONUNBUFFERED so lines appear immediately, not on a buffer flush.
#   run_svc <tmp-log> <prefix> <dir> <cmd...>
run_svc() {
  local tmplog="$1" prefix="$2" dir="$3"; shift 3
  ( cd "$dir" && PYTHONUNBUFFERED=1 "$@" ) 2>&1 \
    | tee "$tmplog" \
    | sed -u "s/^/[$prefix] /" &
}

echo "[shared] starting x-ray models on GPU ..."
run_svc /tmp/cliniq_shared_bone.log     bone-detect   bone-detect   python api/server.py
sleep 2
run_svc /tmp/cliniq_shared_oralxray.log oral-xray     oral-xray     python api/server.py
sleep 2
run_svc /tmp/cliniq_shared_chest.log    chest-xray    chest_xray    python -m api.server
sleep 2
run_svc /tmp/cliniq_shared_classify.log oral-classify oral-classify python -m api.server
sleep 2

wait_health 8001 "bone-detect"    || true
wait_health 8002 "oral-xray"      || true
wait_health 8003 "chest-xray"     || true
wait_health 8004 "oral-classify"  || true

# --- 2a) Prescription parser (:8005) — heavy VLM, opt out with SKIP_PRESCRIPTION=1
# Qwen2-VL-2B is fetched from HuggingFace on first load (~5GB) and stays in the
# HF cache afterwards, so the first boot on a clean cache is slow.
if [ "${SKIP_PRESCRIPTION:-0}" != "1" ]; then
  echo "[shared] starting prescription-parser (:8005) ..."
  run_svc /tmp/cliniq_shared_rx.log prescription prescription-parser python api/server.py
  sleep 3
  wait_health 8005 "prescription-parser" || \
    echo "[shared] ! prescription-parser slow to load (VLM download?) — see /tmp/cliniq_shared_rx.log"
else
  echo "[shared] prescription-parser skipped (SKIP_PRESCRIPTION=1)"
fi

# --- 2b) Triage worklist (:8010) — only meaningful with a queue backend -------
# The x-ray services above already attached their queue workers at import time
# (messaging.fastapi_integration.attach_worker), since QUEUE_BACKEND was in the
# environment before they started. Triage consumes cliniq:results.
if [ "$QUEUE_MODE" != "none" ] && [ -n "$QUEUE_MODE" ]; then
  echo "[shared] starting triage worklist (:8010) ..."
  run_svc /tmp/cliniq_shared_triage.log triage triage python app.py
  sleep 2
  wait_health 8010 "triage" || true
else
  echo "[shared] triage skipped (QUEUE_BACKEND=none)"
fi

# --- 3) Summary table (Node / GPU / CUDA per service) -------------------------
echo "[shared] building summary ..."
python "$ROOT/slurm/gpu_summary.py" | tee "$SUMMARY_FILE"

# --- 4) Chatbot (:5000) --------------------------------------------------------
# PYTHONUNBUFFERED so the request-log lines appear immediately, not on a buffer
# flush. Output is tee'd: a [chatbot] prefix into THIS job's stdout (the SLURM
# log you tail), and the full copy into /tmp for a node-local deep dive. This is
# what surfaces the [req] method/path/status/traceback lines in the terminal.
echo "[shared] starting chatbot (:5000) ..."
run_svc /tmp/cliniq_shared_chatbot.log chatbot chatbot-app python app.py
wait_health 5000 "chatbot" || true

# --- 4a) Chat bridge — puts the chatbot behind Redis for the backend ----------
# The public backend cannot HTTP the chatbot on this private node, so it talks to
# it over the queue instead. Only meaningful with a broker configured.
if [ "$QUEUE_MODE" != "none" ] && [ -n "$QUEUE_MODE" ]; then
  echo "[shared] starting chat bridge (cliniq:chat:requests) ..."
  python -m messaging.chat_bridge > /tmp/cliniq_shared_chatbridge.log 2>&1 &
else
  echo "[shared] chat bridge skipped (QUEUE_BACKEND=none)"
fi

# Signal the login-node launcher that the stack is up.
touch "$READY_FILE"

echo "==================================================================="
echo "[shared] READY — full stack on $NODE_HOST"
echo "[shared] reach the chatbot:  ssh -L 5000:$NODE_HOST:5000 <login-node>"
echo "[shared]                     then open http://127.0.0.1:5000"
echo "==================================================================="

# Keep the allocation alive so the services stay up.
wait
